{
  "schemaVersion": 1,
  "id": "autobookshelf-addon",
  "version": "${version}",
  "name": "AutoBookshelf-addon",
  "description": "Meteor Addon for Timid Bookkeeper and Yuri Enjoyers",
  "authors": [
    "oehrasa"
  ],
  "contact": {
    "homepage": "https://github.com/oehrasa/Oehrasa-Bookies-Addon",
    "repo": "https://github.com/oehrasa",
    "issues": "https://github.com/oehrasa/Oehrasa-Bookies-Addon/issues"
  },
  "license": "GPL-3.0",
  "icon": "assets/oehrasa/textures/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.AutoBookshelf.addon.Addon"
    ]
  },
  "accessWidener": "oehrasa.accesswidener",
  "mixins": [
    "oehrasa-addon.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,225,28"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
